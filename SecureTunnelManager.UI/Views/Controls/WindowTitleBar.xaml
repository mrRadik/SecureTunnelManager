<UserControl x:Class="SecureTunnelManager.UI.Views.Controls.WindowTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="40"
             HorizontalAlignment="Stretch"
             Background="{StaticResource StmTitleBarBrush}"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <Grid MouseLeftButtonDown="OnTitleBarMouseDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
            <Image Source="pack://application:,,,/Assets/app.ico"
                   Width="16" Height="16"
                   Margin="0,0,8,0"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock x:Name="TitleText"
                       FontFamily="Segoe UI"
                       FontSize="12"
                       Foreground="{StaticResource StmTextPrimaryBrush}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Column="1" Background="Transparent" MouseLeftButtonDown="OnTitleBarMouseDown"/>

        <StackPanel Grid.Column="2" Orientation="Horizontal">
            <Button Style="{StaticResource StmTitleBarButton}" Click="OnMinimizeClick" ToolTip="Minimize">
                <TextBlock Text="&#xE921;" FontFamily="Segoe Fluent Icons" FontSize="10"/>
            </Button>
            <Button x:Name="MaximizeButton"
                    Style="{StaticResource StmTitleBarButton}"
                    Click="OnMaximizeClick"
                    ToolTip="Maximize"
                    Visibility="{Binding ShowMaximizeButton, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock x:Name="MaximizeGlyph" Text="&#xE922;" FontFamily="Segoe Fluent Icons" FontSize="10"/>
            </Button>
            <Button Style="{StaticResource StmTitleBarCloseButton}" Click="OnCloseClick" ToolTip="Close">
                <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons" FontSize="10"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
