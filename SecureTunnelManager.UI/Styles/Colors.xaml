<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="StmBackgroundColor">#1E1E1E</Color>
    <Color x:Key="StmSurfaceColor">#252526</Color>
    <Color x:Key="StmCardColor">#2D2D30</Color>
    <Color x:Key="StmSidebarColor">#252526</Color>
    <Color x:Key="StmTextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="StmTextSecondaryColor">#B8B8B8</Color>
    <Color x:Key="StmAccentColor">#0078D4</Color>
    <Color x:Key="StmAccentHoverColor">#1A86D9</Color>
    <Color x:Key="StmAccentSubtleColor">#1A0078D4</Color>
    <Color x:Key="StmSuccessColor">#107C10</Color>
    <Color x:Key="StmSuccessHoverColor">#0E6B0E</Color>
    <Color x:Key="StmErrorColor">#F1707B</Color>
    <Color x:Key="StmDestructiveColor">#C42B1C</Color>
    <Color x:Key="StmDestructiveHoverColor">#A52618</Color>
    <Color x:Key="StmBorderColor">#3A3A3A</Color>
    <Color x:Key="StmHoverColor">#333337</Color>
    <Color x:Key="StmSelectedColor">#094771</Color>
    <Color x:Key="StmDisabledTextColor">#6D6D6D</Color>
    <Color x:Key="StmDisabledBackgroundColor">#2A2A2A</Color>
    <Color x:Key="StmWarningColor">#CA5010</Color>

    <SolidColorBrush x:Key="StmBackgroundBrush" Color="{StaticResource StmBackgroundColor}"/>
    <SolidColorBrush x:Key="StmSurfaceBrush" Color="{StaticResource StmSurfaceColor}"/>
    <SolidColorBrush x:Key="StmCardBrush" Color="{StaticResource StmCardColor}"/>
    <SolidColorBrush x:Key="StmSidebarBrush" Color="{StaticResource StmSidebarColor}"/>
    <SolidColorBrush x:Key="StmTextPrimaryBrush" Color="{StaticResource StmTextPrimaryColor}"/>
    <SolidColorBrush x:Key="StmTextSecondaryBrush" Color="{StaticResource StmTextSecondaryColor}"/>
    <SolidColorBrush x:Key="StmAccentBrush" Color="{StaticResource StmAccentColor}"/>
    <SolidColorBrush x:Key="StmAccentHoverBrush" Color="{StaticResource StmAccentHoverColor}"/>
    <SolidColorBrush x:Key="StmAccentSubtleBrush" Color="{StaticResource StmAccentSubtleColor}"/>
    <SolidColorBrush x:Key="StmSuccessBrush" Color="{StaticResource StmSuccessColor}"/>
    <SolidColorBrush x:Key="StmSuccessHoverBrush" Color="{StaticResource StmSuccessHoverColor}"/>
    <SolidColorBrush x:Key="StmErrorBrush" Color="{StaticResource StmErrorColor}"/>
    <SolidColorBrush x:Key="StmDestructiveBrush" Color="{StaticResource StmDestructiveColor}"/>
    <SolidColorBrush x:Key="StmDestructiveHoverBrush" Color="{StaticResource StmDestructiveHoverColor}"/>
    <SolidColorBrush x:Key="StmBorderBrush" Color="{StaticResource StmBorderColor}"/>
    <SolidColorBrush x:Key="StmHoverBrush" Color="{StaticResource StmHoverColor}"/>
    <SolidColorBrush x:Key="StmSelectedBrush" Color="{StaticResource StmSelectedColor}"/>
    <SolidColorBrush x:Key="StmDisabledTextBrush" Color="{StaticResource StmDisabledTextColor}"/>
    <SolidColorBrush x:Key="StmDisabledBackgroundBrush" Color="{StaticResource StmDisabledBackgroundColor}"/>
    <SolidColorBrush x:Key="StmWarningBrush" Color="{StaticResource StmWarningColor}"/>

</ResourceDictionary>
