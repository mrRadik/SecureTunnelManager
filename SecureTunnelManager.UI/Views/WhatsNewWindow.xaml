<windows:StmChromeWindow x:Class="SecureTunnelManager.UI.Views.WhatsNewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SecureTunnelManager.UI.Views.Controls"
        xmlns:windows="clr-namespace:SecureTunnelManager.UI.Windows"
        Style="{StaticResource StmDialogWindow}"
        Width="680"
        Height="560"
        MinWidth="560"
        MinHeight="440"
        WindowStartupLocation="CenterOwner">

    <Grid Background="{StaticResource StmBackgroundBrush}"
          SnapsToDevicePixels="True"
          UseLayoutRounding="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <controls:WindowTitleBar x:Name="TitleBar" Grid.Row="0" ShowMaximizeButton="False"/>

        <Grid Grid.Row="1" Margin="24,20,24,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="SubtitleText" Grid.Row="0" Style="{StaticResource StmPageSubtitle}" Margin="0,0,0,16"/>
            <Border Grid.Row="1" Style="{StaticResource StmCard}" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="ReleaseNotesText"
                               Style="{StaticResource StmBody}"
                               TextWrapping="Wrap"
                               LineHeight="22"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource StmDialogFooter}">
            <Button x:Name="OkButton"
                    IsDefault="True"
                    IsCancel="True"
                    Click="OnOkClick"
                    Style="{StaticResource StmPrimaryButton}"
                    HorizontalAlignment="Right"
                    MinWidth="120"/>
        </Border>
    </Grid>
</windows:StmChromeWindow>
