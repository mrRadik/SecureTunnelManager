<UserControl x:Class="SecureTunnelManager.UI.Views.Controls.PasswordVaultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Password Vault" Style="{StaticResource StmPageTitle}"/>
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource StmPageSubtitle}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="Unlock Vault"
                    Command="{Binding UnlockCommand}"
                    Style="{StaticResource StmPrimaryButton}"
                    Margin="0,0,8,0"
                    Visibility="{Binding IsVaultUnlocked, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
            <Button Content="Lock Vault"
                    Command="{Binding LockVaultCommand}"
                    Style="{StaticResource StmSecondaryButton}"
                    Visibility="{Binding IsVaultUnlocked, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource StmCard}" Margin="0" Padding="0"
                Visibility="{Binding IsVaultUnlocked, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ListBox ItemsSource="{Binding Credentials}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="8">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="8,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Username}" Style="{StaticResource StmPageSubtitle}" Margin="0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CreatedDate, StringFormat='Added {0:yyyy-MM-dd}'}"
                                       Style="{StaticResource StmPageSubtitle}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource StmCard}" Margin="0"
                Visibility="{Binding IsVaultUnlocked, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
                <TextBlock Text="&#xE192;" FontFamily="Segoe Fluent Icons" FontSize="32"
                           Foreground="{StaticResource StmAccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Vault is locked" Style="{StaticResource StmEmptyStateTitle}"/>
                <TextBlock Text="Unlock the vault to view credentials stored for your tunnels."
                           Style="{StaticResource StmEmptyStateText}" MaxWidth="360"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
