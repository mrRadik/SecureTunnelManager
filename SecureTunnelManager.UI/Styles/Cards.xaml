<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="StmTunnelCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StmCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource StmBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="StmCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StmCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource StmBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Margin" Value="16"/>
    </Style>

    <Style x:Key="StmMetricCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StmCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource StmBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,12,0"/>
        <Setter Property="MinWidth" Value="150"/>
    </Style>

    <Style x:Key="StmStatCard" TargetType="Border" BasedOn="{StaticResource StmMetricCard}"/>

    <Style x:Key="StmListRow" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <Style x:Key="StmListRowHover" TargetType="Border" BasedOn="{StaticResource StmListRow}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource StmHoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="StmWizardStep" TargetType="Border">
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Background" Value="{StaticResource StmSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource StmBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="StmWizardStepActive" TargetType="Border" BasedOn="{StaticResource StmWizardStep}">
        <Setter Property="Background" Value="{StaticResource StmSelectedBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource StmAccentBrush}"/>
    </Style>

</ResourceDictionary>
