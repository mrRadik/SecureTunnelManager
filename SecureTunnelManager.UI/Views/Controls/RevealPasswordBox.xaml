<UserControl x:Class="SecureTunnelManager.UI.Views.Controls.RevealPasswordBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <Grid Height="40">
        <PasswordBox x:Name="HiddenBox"
                     Style="{StaticResource StmInputPassword}"
                     Margin="0"
                     Height="40"
                     PasswordChanged="OnPasswordChanged"
                     Visibility="{Binding IsRevealed, ElementName=Root, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
        <TextBox x:Name="VisibleBox"
                 Style="{StaticResource StmInput}"
                 Margin="0"
                 Height="40"
                 TextChanged="OnTextChanged"
                 Visibility="{Binding IsRevealed, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <Button HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,8,0"
                Style="{StaticResource StmGhostButton}"
                MinWidth="32"
                MinHeight="32"
                Padding="6"
                Click="OnToggleReveal"
                ToolTip="Show or hide password">
            <TextBlock x:Name="RevealGlyph" Text="&#xED1A;" FontFamily="Segoe Fluent Icons" FontSize="14"/>
        </Button>
    </Grid>
</UserControl>
