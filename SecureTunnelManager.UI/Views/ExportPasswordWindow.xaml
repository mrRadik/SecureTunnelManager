<windows:StmChromeWindow x:Class="SecureTunnelManager.UI.Views.ExportPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SecureTunnelManager.UI.Views.Controls"
        xmlns:windows="clr-namespace:SecureTunnelManager.UI.Windows"
        Title="Export Password"
        Style="{StaticResource StmDialogWindow}"
        Width="440"
        Height="260"
        WindowStartupLocation="CenterOwner">

    <Grid Background="{StaticResource StmBackgroundBrush}"
          SnapsToDevicePixels="True"
          UseLayoutRounding="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <controls:WindowTitleBar x:Name="TitleBar" Grid.Row="0" Title="Export Password" ShowMaximizeButton="False"/>

            <StackPanel Grid.Row="1" Margin="24,20">
                <TextBlock x:Name="HintText" TextWrapping="Wrap" Style="{StaticResource StmBody}" Margin="0,0,0,16"/>
                <TextBlock Text="Password" Style="{StaticResource StmLabel}"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource StmInputPassword}"/>
            </StackPanel>

            <Border Grid.Row="2" Style="{StaticResource StmDialogFooter}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" IsCancel="True" Style="{StaticResource StmGhostButton}" Margin="0,0,8,0"/>
                    <Button Content="OK" IsDefault="True" Click="OnOkClick" Style="{StaticResource StmPrimaryButton}"/>
                </StackPanel>
            </Border>
    </Grid>
</windows:StmChromeWindow>
