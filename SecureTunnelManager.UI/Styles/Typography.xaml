<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="StmFontBase" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Foreground" Value="{StaticResource StmTextPrimaryBrush}"/>
    </Style>

    <Style x:Key="StmPageTitle" TargetType="TextBlock" BasedOn="{StaticResource StmFontBase}">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="{x:Static FontWeights.SemiBold}"/>
    </Style>

    <Style x:Key="StmPageSubtitle" TargetType="TextBlock" BasedOn="{StaticResource StmFontBase}">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource StmTextSecondaryBrush}"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>

    <Style x:Key="StmCardTitle" TargetType="TextBlock" BasedOn="{StaticResource StmFontBase}">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="{x:Static FontWeights.SemiBold}"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <Style x:Key="StmLabel" TargetType="TextBlock" BasedOn="{StaticResource StmFontBase}">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource StmTextSecondaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="StmBody" TargetType="TextBlock" BasedOn="{StaticResource StmFontBase}">
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="StmValidationError" TargetType="TextBlock" BasedOn="{StaticResource StmFontBase}">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource StmErrorBrush}"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>

    <Style x:Key="StmEmptyStateTitle" TargetType="TextBlock" BasedOn="{StaticResource StmFontBase}">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="{x:Static FontWeights.SemiBold}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="StmEmptyStateText" TargetType="TextBlock" BasedOn="{StaticResource StmFontBase}">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource StmTextSecondaryBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,8,0,0"/>
    </Style>

    <Style x:Key="StmNavSectionHeader" TargetType="TextBlock" BasedOn="{StaticResource StmFontBase}">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource StmTextSecondaryBrush}"/>
        <Setter Property="Margin" Value="12,16,0,6"/>
        <Setter Property="Opacity" Value="0.85"/>
    </Style>

    <Style x:Key="StmSidebarAppTitle" TargetType="TextBlock" BasedOn="{StaticResource StmFontBase}">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="StmSummaryText" TargetType="TextBlock" BasedOn="{StaticResource StmFontBase}">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource StmTextSecondaryBrush}"/>
        <Setter Property="Margin" Value="0,0,16,0"/>
    </Style>

    <Style x:Key="StmRouteLabel" TargetType="TextBlock" BasedOn="{StaticResource StmFontBase}">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource StmTextSecondaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <Style x:Key="StmRouteValue" TargetType="TextBlock" BasedOn="{StaticResource StmFontBase}">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="Consolas"/>
    </Style>

</ResourceDictionary>
